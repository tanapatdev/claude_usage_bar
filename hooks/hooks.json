{
  "description": "Auto-launch the Claude Usage menu bar app if it isn't already running",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PLUGIN_ROOT/hooks/scripts/launch-usage-bar.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
